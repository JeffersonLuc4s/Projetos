# ─────────────────────────────────────────────
# Grimório do Aventureiro — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA suba o .env para o GitHub!
# ─────────────────────────────────────────────

# String de conexão do Neon PostgreSQL
# Formato: postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://SEU_USUARIO:SUA_SENHA@SEU_HOST_NEON/SEU_BANCO?sslmode=require

# Segredo para assinar os tokens JWT
# Gere um valor seguro com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque-por-uma-frase-longa-e-aleatoria-aqui

# Porta local (opcional, padrão: 3000)
PORT=3000
